{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "清洁王",
  "version": "0.1.0",
  "identifier": "com.yangbuyiya.tidymac",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "清洁王",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "tooltip": "清洁王",
      "showMenuOnLeftClick": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2MkNDNTZBNTEwN0JCODQKUldTRXV3ZFJhc1VzTnJ2d3QvQkV4aHZYb2kzUjN2RVhiR1Yrcy9HQ2d2OWQ4TXNwQjBRTC8vcEcK",
      "endpoints": [
        "https://github.com/yangbuyiya/tidy-mac/releases/latest/download/latest.json"
      ]
    }
  }
}
