{
  "name": "tidy-mac",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "release:mac": "TAURI_SIGNING_PRIVATE_KEY=\"$(cat ~/.tauri/tidy-mac.key)\" TAURI_SIGNING_PRIVATE_KEY_PASSWORD= tauri build && node scripts/generate-latest-json.mjs",
    "release:mac:ci": "tauri build && node scripts/generate-latest-json.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
